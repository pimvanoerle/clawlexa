menu "clawlexa"

config CLAWLEXA_HEADLESS
    bool "Headless mode (skip display/touch bring-up)"
    default n
    help
        Skip peripheral (display, touch) initialization in app_main. Intended
        for emulation (QEMU) or host CI where the LCD/touch hardware is absent
        and their init would abort. The boot banner and heartbeat still run, so
        the core boot path can be smoke-tested without a board.

        Leave disabled (n) for real-hardware builds.

config CLAWLEXA_MIC_DUMP_ON_BOOT
    bool "Dump a mic recording over serial on boot"
    default n
    help
        Record a few seconds from the mic at boot and dump it as base64 over the
        console for tools/capture_mic.py. Off by default — it floods the console
        on every boot. Enable it (or build a dedicated capture image) when you
        want to grab a recording; mic_init() runs regardless.

config CLAWLEXA_BOOT_CHIME
    bool "Play the boot chime through the speaker on boot"
    default n
    help
        Play the embedded boot.wav through the speaker at startup. Off by default
        to keep boot quiet. audio_play_init() runs regardless, so the speaker
        still works for bridge replies.

config CLAWLEXA_WIFI_SSID
    string "WiFi SSID"
    default ""
    help
        SSID of the WiFi network to join (station mode). Set this in your local
        sdkconfig via `idf.py menuconfig` — it is gitignored, so credentials
        never get committed. Empty = no connection attempt.

config CLAWLEXA_WIFI_PASS
    string "WiFi password"
    default ""
    help
        Password for CLAWLEXA_WIFI_SSID (WPA2). Leave empty for an open network.
        Stored only in your local (gitignored) sdkconfig.

config CLAWLEXA_BRIDGE_HOST
    string "Bridge host (IP or hostname)"
    default ""
    help
        Host running clawlexa-bridge. The device dials ws://<host>:<port>. Set
        to the bridge laptop's LAN IP. Empty = don't connect to the bridge.

config CLAWLEXA_BRIDGE_PORT
    int "Bridge port"
    default 8765
    help
        TCP port clawlexa-bridge listens on (default 8765).

config CLAWLEXA_STREAM_MIC_ON_CONNECT
    bool "Stream a few seconds of mic to the bridge on connect"
    default n
    help
        Once connected to the bridge, stream a short mic recording over the
        WebSocket (the bridge saves it as a WAV). Phase 2c bring-up behavior —
        off by default; enable to exercise the device->bridge audio path.

endmenu
